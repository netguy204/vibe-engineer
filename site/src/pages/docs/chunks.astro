      <div class="evo-tree"><pre><code>docs/
└── chunks/
    └── auth_session_refresh/
        ├── GOAL.md
        └── PLAN.md
src/
└── auth/
    └── <span class="evo-changed">middleware.py</span>    <span class="evo-tag">new</span></code></pre></div>
      <p class="evo-filename">src/auth/middleware.py</p>
      <pre><code><span class="evo-bref"># Chunk: docs/chunks/auth_session_refresh - Refresh expired sessions via rotation</span>

from fastapi import Request, Response
from .service import auth_service, ExpiredSignatureError, RotationFailed


async def refresh_session_if_expired(request: Request, call_next):
    try:
        return await call_next(request)
    except ExpiredSignatureError:
        try:
            new_access, new_refresh = auth_service.rotate_refresh_token(
                request.cookies.get("refresh_token")
            )
        except RotationFailed:
            return Response(status_code=401)

        request.headers["authorization"] = f"Bearer &#123;new_access&#125;"
        response = await call_next(request)
        response.set_cookie("refresh_token", new_refresh, httponly=True)
        return response</code></pre>
