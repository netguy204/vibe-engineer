---
// Chunk: docs/chunks/landing_page_veng_dev
import type { CodeLine } from '../data/hero-code';

interface Props {
  lines: CodeLine[];
  showBackreferences?: boolean;
  dimmed?: boolean;
}

const { lines, showBackreferences = true, dimmed = false } = Astro.props;

let filteredLines = showBackreferences
  ? lines
  : lines.filter(line => line.type !== 'backreference');

// Collapse consecutive blank lines that appear when backreferences are stripped
if (!showBackreferences) {
  filteredLines = filteredLines.filter((line, i, arr) => {
    if (line.text === '' && i > 0 && arr[i - 1].text === '') return false;
    return true;
  });
}

const html = filteredLines.map(line => {
  const cls = line.type === 'plain' ? '' : ` class="${line.type}"`;
  const escaped = line.text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return `<span${cls}>${escaped}</span>`;
}).join('\n');
---

<div class:list={['code-block', { dimmed }]} tabindex="0" role="region" aria-label="Code example">
  <pre><code set:html={html} /></pre>
</div>
