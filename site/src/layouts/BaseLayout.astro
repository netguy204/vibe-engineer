---
// Chunk: docs/chunks/landing_page_veng_dev
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 've — documentation-driven development',
  description = 'Your codebase doesn\'t remember why. VE fixes that. Documentation-driven development for AI-assisted coding.',
} = Astro.props;

const siteUrl = 'https://veng.dev';
const ogImage = `${siteUrl}/og-image.svg`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={siteUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={siteUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Analytics -->
  <script defer src="https://analytics.veng.dev/script.js" data-website-id="45c5153f-764f-4e64-8ae3-21a8db285393"></script>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>

  <slot name="nav" />

  <main id="main-content">
    <slot />
  </main>

  <footer>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
